# ============================================================
# .gitignore — Version control exclusions for dotfiles repo.
# Files listed here contain sensitive or machine-specific data
# that must not be committed to the repository.
# ============================================================

# Per-machine device configuration containing sensitive tokens.
eww/device.conf

# Local mail storage for notmuch + lieer Gmail integration.
.mail/
.notmuch-config

# Icon setup failure log generated by setup-icons.sh.
eww/.icon-setup-failed

# material-icons repository is initialized by install.sh.
# It is excluded because of its large size (200MB+).
eww/material-icons/

# Generated icon SVGs are excluded because they are produced
# by setup-icons.sh from the material-icons source on each machine.
eww/icons/

# OS and editor artifacts.
.DS_Store
*.swp
*.swo
*~
eww/modules/windows.yuck
